{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": ".",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@/modules/auth/*": ["./src/domains/auth/*"],
      "@/modules/brand-dna/*": ["./src/domains/creation-studio/brand-dna/*"],
      "@/modules/chat-coach-modal/*": ["./src/domains/creation-studio/chat-coach/chat-coach-modal/*"],
      "@/modules/chat-coach/*": ["./src/domains/creation-studio/chat-coach/*"],
      "@/modules/video-creator/*": ["./src/domains/creation-studio/video-creator/*"],
      "@/modules/content-post/*": ["./src/domains/dashboard/calendar/content-post/*"],
      "@/modules/campaigns/*": ["./src/domains/dashboard/management/campaigns/*"],
      "@/modules/dashboard/*": ["./src/domains/dashboard/*"],
      "@/modules/social-network/*": ["./src/domains/social-network/*"],
      "@/modules/create-post/*": ["./src/modules/creation-studio/*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src"]
}
